	"C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: WebKit, ColumnLimit: 100 }",
	"C_Cpp.clang_format_style": "WebKit",
	"cSpell.words": ["Wumpus"],
	"cSpell.allowCompoundWords": true,
	"cSpell.language": "en-US,es-ES",
	"cSpell.languageSettings": [
		{
			"languageId": "*",
			"caseSensitive": false
		},
		{
			"languageId": "markdown",
			"caseSensitive": true
		}
	],
	"editor.formatOnSave": true,
	"editor.wordWrap": "off",
	"[markdown]": {
		"editor.wordWrap": "off"
	},
	"editor.tabSize": 4
}
